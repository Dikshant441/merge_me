enum Gender {
  Male
  Female
  Other
}

model User {
  id             String   @id @default(cuid())
  first_name     String   @db.VarChar(30)
  last_name      String?
  email          String   @unique
  password       String
  age            Int?
  gender         Gender?
  isPremium      Boolean  @default(false)
  membershipType String?
  photoURL       String   @default("https://www.example.com/default-photo.jpg")
  about          String   @default("This is about me section.")
  skills         String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sentRequests     ConnectionRequest[] @relation("SentRequests")
  receivedRequests ConnectionRequest[] @relation("ReceivedRequests")
  payments         Payment[]
}
