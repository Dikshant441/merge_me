# ─── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Used by the app (src/db/index.ts), drizzle-kit, and the data
# migration script. Neon: use the pooled URL here.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mergeme
# Direct (non-pooled) URL — some drizzle-kit operations prefer it.
DATABASE_URL_UNPOOLED=postgres://postgres:postgres@localhost:5432/mergeme

# ─── MongoDB (legacy — chat/payment/profile still use it) ───────
# Also required by scripts/migrate-mongo-to-postgres.ts.
# Include the database name in the URI.
MONGODB_URI=mongodb://localhost:27017/mergeme

# ─── Auth ────────────────────────────────────────────────────────
JWT_SECRET=change-me            # legacy Mongo-session JWT
JWT_ACCESS_SECRET=change-me     # new access_token cookie
COOKIE_REFRESH_PATH=/auth

# ─── OAuth ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

# ─── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=
MAILER_SEND_IN_DEV=false

# ─── Payments (Razorpay) ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
